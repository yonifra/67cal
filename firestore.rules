rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }

    // Helper functions using get() — for subcollection rules that need
    // to look up the parent calendar document
    function calendarOwner(calId) {
      return get(/databases/$(database)/documents/calendars/$(calId)).data.ownerId;
    }
    function calendarMembers(calId) {
      return get(/databases/$(database)/documents/calendars/$(calId)).data.members;
    }
    function calendarCollaborators(calId) {
      return get(/databases/$(database)/documents/calendars/$(calId)).data.collaborators;
    }
    function canEditCalendar(calId) {
      return calendarOwner(calId) == request.auth.uid
          || request.auth.uid in calendarCollaborators(calId);
    }

    match /notifications/{notificationId} {
      allow read: if isAuth()
        && resource.data.recipientId == request.auth.uid;
      allow update: if isAuth()
        && resource.data.recipientId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }

    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId
        && request.resource.data.uid == resource.data.uid;  // prevent uid tampering
    }

    match /calendars/{calId} {
      // Use resource.data (not get()) so collection queries work.
      // Query patterns used by the app:
      //   1. where('ownerId', '==', uid)                        → owner dashboard
      //   2. where('members', 'array-contains', uid)            → joined calendars
      //   3. where('collaborators', 'array-contains', uid)      → collaborating calendars
      //   4. where('inviteCode', '==', code)                    → pupil invite join flow
      //   5. where('collaboratorInviteCode', '==', code)        → collaborator invite join flow
      allow read: if isAuth()
        && (resource.data.ownerId == request.auth.uid
            || request.auth.uid in resource.data.members
            || request.auth.uid in resource.data.collaborators
            || resource.data.inviteCode is string
            || resource.data.collaboratorInviteCode is string);
      allow create: if isAuth();
      // Owner can update anything; collaborators can update but NOT touch
      // ownerId, collaborators, collaboratorInviteCode, inviteCode, members, passwordHash
      allow update: if isAuth()
        && (resource.data.ownerId == request.auth.uid
            || (request.auth.uid in resource.data.collaborators
                && request.resource.data.ownerId == resource.data.ownerId
                && request.resource.data.collaborators == resource.data.collaborators
                && request.resource.data.collaboratorInviteCode == resource.data.collaboratorInviteCode
                && request.resource.data.inviteCode == resource.data.inviteCode
                && request.resource.data.members == resource.data.members
                && request.resource.data.passwordHash == resource.data.passwordHash));
      allow delete: if isAuth()
        && resource.data.ownerId == request.auth.uid;

      match /events/{eventId} {
        allow read: if isAuth()
          && (calendarOwner(calId) == request.auth.uid
              || request.auth.uid in calendarMembers(calId)
              || request.auth.uid in calendarCollaborators(calId));
        allow write: if isAuth()
          && canEditCalendar(calId);

        match /messages/{msgId} {
          allow read: if isAuth()
            && (calendarOwner(calId) == request.auth.uid
                || request.auth.uid in calendarMembers(calId)
                || request.auth.uid in calendarCollaborators(calId));
          allow create: if isAuth()
            && (calendarOwner(calId) == request.auth.uid
                || request.auth.uid in calendarMembers(calId)
                || request.auth.uid in calendarCollaborators(calId));
          allow update, delete: if isAuth()
            && (request.auth.uid == resource.data.authorId
                || canEditCalendar(calId));
        }

        match /files/{fileId} {
          allow read: if isAuth()
            && (calendarOwner(calId) == request.auth.uid
                || request.auth.uid in calendarMembers(calId)
                || request.auth.uid in calendarCollaborators(calId));
          allow write: if isAuth()
            && canEditCalendar(calId);
        }
      }
    }
  }
}
